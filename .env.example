# ========================
# Binance API 配置
# ========================

# 生产环境API密钥（必须设置）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 测试环境专用API密钥（可选，如果设置则使用专用测试密钥）
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# 默认使用测试环境（true: 测试环境, false: 生产环境）
# 注意：机器人启动时会使用这个设置，但可以在面板中切换
BINANCE_TESTNET=true

# ========================
# Telegram Bot 配置
# ========================

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# ========================
# 交易默认参数
# ========================

DEFAULT_SIDE=long
DEFAULT_LEVERAGE=5
DEFAULT_MARGIN_USDT=50
DEFAULT_TP_PCT=5
DEFAULT_SL_PCT=2

# ========================
# SSL 配置（可选）
# ========================

# SSL证书文件路径（如果需要自定义SSL证书）
# SSL_CERT_FILE=
